# Supabase project settings — Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never prefix with NEXT_PUBLIC_, never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Branding — the single place the platform name is set. See AGENTS.md Section 10.
NEXT_PUBLIC_APP_NAME="Escrow Trustlock"

# Fallback WhatsApp number used before /admin/settings has been configured
# in the database (E.164 digits only, no "+"). e.g. 15550001234
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Absolute origin used to build links in emails and auth redirects (invite
# links, "confirm your email", password reset). MUST be set to your real
# deployed URL in every non-local environment (e.g. in Vercel's project
# settings, e.g. https://escrowtrustlock.online) — left unset, it silently
# falls back to localhost and every link in every email will be broken in
# production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email (SMTP) — these are only a fallback. The primary way to
# configure this is /admin/settings in the running app (no redeploy needed);
# these env vars are used only if that admin-configured email_settings row
# is empty. Without either one set, the app falls back to in-app
# notifications only and logs a warning instead of sending mail. Required
# for real usage: without it, invited counterparties who don't already have
# an account have no way to find out they were invited. Works with any SMTP
# provider (Hostinger, etc.) — port 465 + MAIL_ENCRYPTION=ssl (implicit TLS)
# or port 587 + MAIL_ENCRYPTION=tls (STARTTLS) both work.
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=notify@example.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=notify@example.com
# Literal display name — do not use Laravel-style "${APP_NAME}" here, Node
# won't expand it. Leave unset to fall back to NEXT_PUBLIC_APP_NAME.
MAIL_FROM_NAME="Escrow Trustlock"
