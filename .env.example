# Supabase project settings — Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never prefix with NEXT_PUBLIC_, never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Branding — the single place the platform name is set. See AGENTS.md
# Section 10: no name/logo has been chosen by the client yet.
NEXT_PUBLIC_APP_NAME="Amana Escrow"

# Fallback WhatsApp number used before /admin/settings has been configured
# in the database (E.164 digits only, no "+"). e.g. 15550001234
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Site URL used to build absolute links in emails/redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email (optional for v1 — in-app notifications work without it).
RESEND_API_KEY=
EMAIL_FROM="Amana Escrow <notifications@example.com>"
