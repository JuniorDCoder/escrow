# Supabase project settings — Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never prefix with NEXT_PUBLIC_, never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Branding — the single place the platform name is set. See AGENTS.md
# Section 10: no name/logo has been chosen by the client yet.
NEXT_PUBLIC_APP_NAME="Amana Escrow"

# Fallback WhatsApp number used before /admin/settings has been configured
# in the database (E.164 digits only, no "+"). e.g. 15550001234
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Absolute origin used to build links in emails and auth redirects (invite
# links, "confirm your email", password reset). MUST be set to your real
# deployed URL in every non-local environment (e.g. in Vercel's project
# settings) — left unset, it silently falls back to localhost and every
# link in every email will be broken in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email — without RESEND_API_KEY set, the app falls back to
# in-app notifications only and logs a warning instead of sending mail.
# Required for real usage: without it, invited counterparties who don't
# already have an account have no way to find out they were invited.
# Get a key at resend.com, verify a sending domain, then set EMAIL_FROM to
# an address on that domain.
RESEND_API_KEY=
EMAIL_FROM="Amana Escrow <notifications@example.com>"
